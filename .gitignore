# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db
__pycache__/

# ─── AI Models (too large for git — use scripts/download_models.sh) ──────────
drive/_system/models/*.gguf
drive/_system/models/*.bin
drive/_system/models/*.safetensors

# ─── Ollama Runtime Binaries (use scripts/download_runtime.sh) ───────────────
drive/_system/runtime/ollama-windows/
drive/_system/runtime/ollama-mac-arm/
drive/_system/runtime/ollama-mac-intel/
drive/_system/runtime/ollama-linux-amd64/
drive/_system/runtime/ollama-linux-arm64/
drive/_system/runtime/ollama-linux/
drive/_system/runtime/python-windows/

# ─── Kiwix ZIM Files (large — use scripts/download_content.sh) ───────────────
drive/_system/knowledge/zim/*.zim

# ─── Downloaded content (generated by download_content.sh — not source code) ─
drive/_system/content/books/
drive/_system/content/zim/
drive/_system/content/manifest.json

# ─── License key files ───────────────────────────────────────────────────────
drive/_system/content/licenses/
drive/_system/content/packs/*.json

# ─── User data — conversations, knowledge base (personal, never in repo) ─────
drive/_system/data/
drive/USER_DATA/conversations/
drive/USER_DATA/ecosystem_key.json
drive/USER_DATA/locked/*
!drive/USER_DATA/locked/README.txt
drive/USER_DATA/unlocked/*
!drive/USER_DATA/unlocked/README.txt
drive/USER_DATA/content/*
!drive/USER_DATA/content/README.txt

# ─── Build Artifacts ──────────────────────────────────────────────────────────
build/
*.img
*.iso
*.dmg

# ─── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.local
*.secret

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Node (if any tooling is added later) ─────────────────────────────────────
node_modules/
.artifacts-archive/
.wrangler/
cloudflare-worker/.wrangler/

# ─── Runtime backups (created by server.py auto-backup) ───────────────────────
drive/_system/_backups/

# Generated at boot from models.json — platform-specific absolute paths
drive/_system/Modelfile.generated
# Debug logs (generated at runtime, contain sensitive boot/request data)
drive/_system/data/logs/

# ─── Development artifacts (session debugging, not product files) ───────────
BRAND_AUDIT_REPORT.md
CORE_STATE_MATRIX.md
MASTER_STATE_DUMP.md
PROMPT_TRUTH_MATRIX.md
