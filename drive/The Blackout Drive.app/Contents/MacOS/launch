#!/bin/bash
# ============================================================
# The Blackout Drive — Mac Application Bundle Launcher
# ============================================================
# This is the single entry point for Mac users.
# Double-click the .app icon in Finder — this runs.
#
# It handles EVERYTHING:
#   1. Strips macOS Gatekeeper quarantine (first-run fix)
#   2. Sets executable permissions
#   3. Launches the AI system
# ============================================================

# Find the drive root (parent of the .app bundle)
APP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/../.." && pwd )"
DRIVE_DIR="$( cd "$APP_DIR/.." && pwd )"
SYSTEM_DIR="$DRIVE_DIR/_system"

# Verify we found the system directory
if [ ! -f "$SYSTEM_DIR/config.sh" ]; then
    # Fallback: check if .app is inside a dir that has _system
    DRIVE_DIR="$APP_DIR"
    SYSTEM_DIR="$DRIVE_DIR/_system"
    if [ ! -f "$SYSTEM_DIR/config.sh" ]; then
        osascript -e 'display dialog "Could not locate The Blackout Drive system files.\n\nMake sure this app is inside the Blackout Drive folder." buttons {"OK"} default button "OK" with icon stop with title "Blackout Drive — Error"'
        exit 1
    fi
fi

LAUNCHER="$SYSTEM_DIR/START_MAC.command"
if [ ! -f "$LAUNCHER" ]; then
    osascript -e "display dialog \"Could not find the launcher script.\nThe drive may be incomplete.\" buttons {\"OK\"} default button \"OK\" with icon stop with title \"Blackout Drive — Error\""
    exit 1
fi

# ── First-run: strip quarantine + set permissions ──────────
xattr -rd com.apple.quarantine "$SYSTEM_DIR/runtime/" 2>/dev/null
xattr -rd com.apple.quarantine "$LAUNCHER" 2>/dev/null
xattr -rd com.apple.quarantine "$SYSTEM_DIR/STOP_BEACON.command" 2>/dev/null
chmod +x "$LAUNCHER"
chmod +x "$SYSTEM_DIR/STOP_BEACON.command" 2>/dev/null

# ── Launch in Terminal ─────────────────────────────────────
open -b com.apple.terminal "$LAUNCHER"
